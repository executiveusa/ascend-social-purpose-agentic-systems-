# Shared
NODE_ENV=production
PUBLIC_SITE_URL=https://example.org
NEXT_PUBLIC_API_URL=https://api.example.org
DEMO_ADMIN_EMAIL=admin@asc3nd.local
DEMO_ADMIN_PASSWORD=change-this-password
JWT_SECRET=change-this-long-random-secret
DATA_DIR=/app/mission-data
ICM_ROOT=/app/icm

# Database / storage. The local app works with file storage by default.
DATABASE_URL=postgres://mission:mission@postgres:5432/mission_os
STORAGE_MODE=json

# Model routing. Use LiteLLM, OpenAI-compatible local server, or leave dry-run.
LITELLM_BASE_URL=http://litellm:4000
LITELLM_API_KEY=
DEFAULT_CHEAP_MODEL=local/qwen2.5:7b
DEFAULT_REASONING_MODEL=openai/gpt-4.1-mini
DEFAULT_CRITICAL_MODEL=anthropic/claude-sonnet-4.5

# Integrations. Empty means dry-run with audit log.
POSTIZ_API_URL=
POSTIZ_API_KEY=
COMPOSIO_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
PI_AGENT_COMMAND=pi
ABSURD_ENABLED=false
SANDCASTLE_ENABLED=false

# API hardening
CORS_ORIGIN=https://example.org,http://localhost:3000
JSON_LIMIT=10mb
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=240

# Agentic Coding Flywheel host path
ACFS_HOME=/opt/agentic-coding-flywheel

# v0.4 Rust production-core services
MISSION_CORE_ADDR=0.0.0.0:4100
MISSION_CONNECT_ADDR=0.0.0.0:4200
PUBLIC_API_URL=https://api.example.org
MISSION_CONNECT_PUBLIC_URL=https://api.example.org

# v0.5 repeatable deployment
DEFAULT_TENANT=asc3nd
HOSTINGER_VPS_IP=
MISSION_PUBLIC_BRIDGE_REQUIRE_IDEMPOTENCY=true
