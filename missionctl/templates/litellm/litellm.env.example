# LiteLLM Environment — Generated by missionctl
# Replace <PLACEHOLDER> values before deployment.

LITELLM_MASTER_KEY=<GENERATED_MASTER_KEY>
LITELLM_DB_URL=postgres://mission:***@postgres:5432/litellm

# Provider API keys (do NOT commit real keys)
LITELLM_OPENAI_API_KEY=<OPENAI_API_KEY>
LITELLM_ANTHROPIC_API_KEY=<ANTHROPIC_API_KEY>

# Optional local model
# OLLAMA_API_BASE=http://ollama:11434

# Langfuse integration
LANGFUSE_PUBLIC_KEY=<LANGFUSE_PUBLIC_KEY>
LANGFUSE_SECRET_KEY=<LANGFUSE_SECRET_KEY>
LANGFUSE_HOST=http://langfuse:3000

# Logging
LITELLM_LOG=ERROR
