# Mission OS Managed Environment — Generated by missionctl
# Replace <PLACEHOLDER> values before deployment.

NODE_ENV=production
PORT=4000

# Tenant
DEFAULT_TENANT=<TENANT_SLUG>

# Public URLs
PUBLIC_SITE_URL=https://<SITE_DOMAIN>
PUBLIC_API_URL=https://<API_DOMAIN>
CORS_ORIGIN=https://<SITE_DOMAIN>,https://<API_DOMAIN>

# Storage
DATA_DIR=/app/mission-data
ICM_ROOT=/app/icm

# Database
POSTGRES_DB=mission_os
POSTGRES_USER=mission
POSTGRES_PASSWORD=<GENERATED_PG_PASSWORD>
DATABASE_URL=postgres://mission:<GENERATED_PG_PASSWORD>@postgres:5432/mission_os

# Auth
JWT_SECRET=<GENERATED_JWT_SECRET>
DEMO_ADMIN_EMAIL=<ADMIN_EMAIL>
DEMO_ADMIN_PASSWORD=CHANGE_THIS_BEFORE_DEPLOY

# LiteLLM
LITELLM_MASTER_KEY=<GENERATED_LITELLM_MASTER_KEY>
LITELLM_OPENAI_API_KEY=<OPENAI_API_KEY>
LITELLM_ANTHROPIC_API_KEY=<ANTHROPIC_API_KEY>

# Langfuse
LANGFUSE_NEXTAUTH_SECRET=<GENERATED_LANGFUSE_SECRET>
LANGFUSE_SALT=<GENERATED_LANGFUSE_SALT>

# Open WebUI
WEBUI_SECRET_KEY=<GENERATED_WEBUI_SECRET>

# Rate limiting
RATE_LIMIT_MAX=240
JSON_LIMIT=10mb

# Optional adapters (leave blank for dry-run)
PI_AGENT_COMMAND=
ABSURD_ENABLED=false
SANDCASTLE_ENABLED=false
COMPOSIO_API_KEY=
POSTIZ_API_URL=
POSTIZ_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
ACFS_HOME=/opt/acfs
