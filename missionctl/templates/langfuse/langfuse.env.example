# Langfuse Environment — Generated by missionctl
# Self-hosted Langfuse for trace observability.

NEXTAUTH_SECRET=<GENERATED_NEXTAUTH_SECRET>
SALT=<GENERATED_SALT>
NEXTAUTH_URL=http://langfuse:3000

# Database (shared Postgres, separate schema)
DATABASE_URL=postgres://mission:***@postgres:5432/langfuse

# Auth
NEXT_PUBLIC_SIGN_IN_METHODS=email

# Optional: Enable clickhouse for high-volume tracing
# CLICKHOUSE_URL=http://clickhouse:8123

# Logging
LOG_LEVEL=warn
