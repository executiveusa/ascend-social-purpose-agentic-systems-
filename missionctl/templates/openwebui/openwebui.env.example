# Open WebUI Environment — Generated by missionctl
# Staff-facing AI workspace. Connects ONLY to LiteLLM.

WEBUI_SECRET_KEY=<GENERATED_WEBUI_SECRET>
LITELLM_API_BASE=http://litellm:4000
OPENAI_API_BASE=http://litellm:4000/v1
OPENAI_API_KEY=<LITELLM_VIRTUAL_KEY_OPENWEBUI>

# Branding
WEBUI_NAME=Mission OS AI Workspace

# Disable signup (auth managed by Mission OS)
ENABLE_SIGNUP=false

# Database (shared Postgres, separate schema)
DATABASE_URL=postgres://mission:***@postgres:5432/openwebui

# Optional: Mission OS auth bridge
MISSION_OS_API_URL=http://mission-api:4000
MISSION_OS_TENANT=<TENANT_SLUG>
