# Hermes Managed Runtime — Environment Template
# Generated by missionctl. Replace <PLACEHOLDER> values before deployment.

# Mission OS connection (Hermes calls Mission OS API for context/approvals)
MISSION_OS_API_URL=http://mission-api:4000
MISSION_OS_TENANT=demo-pnw
MISSION_OS_OPERATOR_KEY=89acc480efaa81177e82051b57f264a88b6d9b4a5a2bfab2

# LiteLLM model gateway (Hermes routes all model calls through LiteLLM)
LITELLM_BASE_URL=http://litellm:4000
LITELLM_API_KEY=<SET_AFTER_LITELLM_SYNC>

# Langfuse observability (Hermes emits traces to Langfuse)
LANGFUSE_PUBLIC_KEY=<SET_AFTER_LANGFUSE_SYNC>
LANGFUSE_SECRET_KEY=<SET_AFTER_LANGFUSE_SYNC>
LANGFUSE_HOST=http://langfuse:3000

# Hermes profile and dashboard
HERMES_PROFILE=demo-pnw-profile
HERMES_DASHBOARD_HOST=127.0.0.1
HERMES_DASHBOARD_PORT=8765
HERMES_DASHBOARD_AUTH_MODE=required

# Terminal backend for tool execution
TERMINAL_BACKEND=docker

# Safety: risky toolsets disabled by default
HERMES_DISABLE_BROWSER=true
HERMES_DISABLE_SHELL=true
HERMES_ALLOWED_TOOLS=drive.read,calendar.read
