# Caddy Managed Bundle — Generated by missionctl
# Routes: API, Site, Open WebUI, Langfuse, Hermes (internal only)

{
  email admin@example.org
}

api.nwyouth.org {
  encode gzip zstd
  reverse_proxy mission-api:4000
}

nwyouth.org {
  encode gzip zstd
  reverse_proxy site:3000
}

# Open WebUI — staff access only, behind auth
nwyouth.org/workspace/* {
  reverse_proxy open-webui:8080
}

# Langfuse — staff access only, behind auth
nwyouth.org/observability/* {
  reverse_proxy langfuse-web:3000
}

# Hermes dashboard — NOT exposed publicly
# Access only via SSH tunnel or internal network
# 127.0.0.1:8765

# Grafana — NOT exposed publicly
# 127.0.0.1:3002

# Prometheus — NOT exposed publicly
# 127.0.0.1:9090

# LiteLLM — internal only, accessed by Hermes and Open WebUI
# litellm:4000 (no public port)
