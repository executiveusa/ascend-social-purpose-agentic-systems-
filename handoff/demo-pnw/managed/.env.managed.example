# Mission OS Managed Environment — Generated by missionctl
# Replace <PLACEHOLDER> values before deployment.

NODE_ENV=production
PORT=4000

# Tenant
DEFAULT_TENANT=demo-pnw

# Public URLs
PUBLIC_SITE_URL=https://demo-pnw.org
PUBLIC_API_URL=https://api.demo-pnw.org
CORS_ORIGIN=https://demo-pnw.org,https://api.demo-pnw.org

# Storage
DATA_DIR=/app/mission-data
ICM_ROOT=/app/icm

# Database
POSTGRES_DB=mission_os
POSTGRES_USER=mission
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgres://mission:change_me@postgres:5432/mission_os

# Auth
JWT_SECRET=change_me
MISSION_OPERATOR_KEY=change_me
DEMO_ADMIN_EMAIL=admin@example.org
DEMO_ADMIN_PASSWORD=CHANGE_THIS_BEFORE_DEPLOY

# LiteLLM
LITELLM_MASTER_KEY=change_me
LITELLM_OPENAI_API_KEY=
LITELLM_ANTHROPIC_API_KEY=

# Langfuse
LANGFUSE_NEXTAUTH_SECRET=change_me
LANGFUSE_SALT=change_me
LANGFUSE_SECRET_KEY=change_me

# Open WebUI
OPENWEBUI_SECRET_KEY=change_me
WEBUI_SECRET_KEY=change_me

# Rate limiting
RATE_LIMIT_MAX=240
JSON_LIMIT=10mb

# Optional adapters (leave blank for dry-run)
PI_AGENT_COMMAND=
ABSURD_ENABLED=false
SANDCASTLE_ENABLED=false
COMPOSIO_API_KEY=
POSTIZ_API_URL=
POSTIZ_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
ACFS_HOME=/opt/acfs
